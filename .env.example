# ──────────────────────────────────────────────────────────────────────────────
# Backend types
# source / dest: s3 | ftp   (default: s3)
# state:         s3 | file  (default: s3)
# ──────────────────────────────────────────────────────────────────────────────
SOURCE_TYPE=s3
DEST_TYPE=s3
STATE_TYPE=s3

# ──────────────────────────────────────────────────────────────────────────────
# AWS shared credentials
# Used as fallback for all S3 configs (source, dest, state).
# In production prefer an IAM role (ECS task role / EC2 instance profile).
# ──────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY_HERE

# ── Source: S3 (SOURCE_TYPE=s3) ───────────────────────────────────────────────
SOURCE_S3_BUCKET=my-source-bucket
# Optional key prefix (folder). Leave empty to list the entire bucket.
SOURCE_S3_PREFIX=data/incoming/
# Per-source overrides (omit to fall back to AWS_* shared credentials above)
# SOURCE_S3_REGION=
# SOURCE_S3_ACCESS_KEY_ID=
# SOURCE_S3_SECRET_ACCESS_KEY=

# ── Source: FTP (SOURCE_TYPE=ftp) ─────────────────────────────────────────────
# SOURCE_FTP_HOST=ftp.example.com
# SOURCE_FTP_USER=ftpuser
# SOURCE_FTP_PASSWORD=secret
# SOURCE_FTP_PORT=21
# SOURCE_FTP_BASE_PATH=/uploads
# SOURCE_FTP_SECURE=false

# ── Source: local folder (SOURCE_TYPE=local) ──────────────────────────────────
# SOURCE_LOCAL_PATH=/mnt/data/incoming

# ── Destination: S3 (DEST_TYPE=s3) ───────────────────────────────────────────
DEST_S3_BUCKET=my-target-bucket
DEST_S3_PREFIX=data/processed/
# Per-dest overrides (omit to fall back to AWS_* shared credentials above)
# DEST_S3_REGION=
# DEST_S3_ACCESS_KEY_ID=
# DEST_S3_SECRET_ACCESS_KEY=

# ── Destination: FTP (DEST_TYPE=ftp) ─────────────────────────────────────────
# DEST_FTP_HOST=ftp.example.com
# DEST_FTP_USER=ftpuser
# DEST_FTP_PASSWORD=secret
# DEST_FTP_PORT=21
# DEST_FTP_BASE_PATH=/processed
# DEST_FTP_SECURE=false

# ── Destination: local folder (DEST_TYPE=local) ───────────────────────────────
# DEST_LOCAL_PATH=/mnt/data/processed

# ── State: S3 (STATE_TYPE=s3) ─────────────────────────────────────────────────
STATE_S3_BUCKET=my-infra-bucket
STATE_S3_KEY=storage-sync-cron/state.json
# Per-state overrides (omit to fall back to AWS_* shared credentials above)
# STATE_S3_REGION=
# STATE_S3_ACCESS_KEY_ID=
# STATE_S3_SECRET_ACCESS_KEY=

# ── State: file (STATE_TYPE=file) ─────────────────────────────────────────────
# STATE_FILE_PATH=./sync-state.json

# ── Cron schedule (default: every 5 minutes) ─────────────────────────────────
CRON_SCHEDULE=*/5 * * * *

# ── Logging ───────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Graceful shutdown timeout (milliseconds) ─────────────────────────────────
SHUTDOWN_TIMEOUT_MS=10000
