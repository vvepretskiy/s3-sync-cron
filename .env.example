# ──────────────────────────────────────────────────────────────────────────────
# AWS Credentials
# In production use an IAM role (ECS task role / EC2 instance profile)
# instead of long-lived access keys.
# ──────────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY_HERE

# ── Source S3 bucket ──────────────────────────────────────────────────────────
SOURCE_BUCKET=my-source-bucket
# Optional prefix (folder). Leave empty to list the entire bucket.
SOURCE_PREFIX=data/incoming/

# ── Destination S3 bucket ─────────────────────────────────────────────────────
DEST_BUCKET=my-target-bucket
DEST_PREFIX=data/processed/

# ── State file location (persists last-run timestamp across container restarts) ─
STATE_BUCKET=my-infra-bucket
STATE_KEY=s3-sync-cron/state.json

# ── Cron schedule (default: every 5 minutes) ─────────────────────────────────
CRON_SCHEDULE=*/5 * * * *

# ── Logging ───────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Graceful shutdown timeout (milliseconds) ─────────────────────────────────
SHUTDOWN_TIMEOUT_MS=10000
